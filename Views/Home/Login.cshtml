@{
    ViewData["Title"] = "Login - ABC University";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 85vh; padding-top: 50px; padding-bottom: 50px;">
    <div class="card shadow-sm border-0 p-4 p-md-5" style="max-width: 480px; width: 100%; border-radius: 28px; background: #fff;">
        
        <div class="text-center mb-4">
            <div class="d-inline-block p-3 rounded-circle mb-3" style="background: rgba(16, 185, 129, 0.1);">
                <i class="bi bi-person-check-fill" style="font-size: 2.5rem; color: var(--portal-emerald);"></i>
            </div>
            <h2 class="fw-bold" style="color: var(--portal-navy); letter-spacing: -1px; font-size: 1.85rem;">Welcome Back</h2>
            <p class="text-muted small">Please enter your details to sign in to your portal</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 small py-2 mb-3" style="border-radius: 12px;">
                <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger border-0 small py-2 mb-3" style="border-radius: 12px;"></div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label fw-600 text-secondary small mb-1">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                        <i class="bi bi-envelope text-muted"></i>
                    </span>
                    <input name="email" type="email" class="form-control border-start-0 py-2" placeholder="name@university.edu" style="border-radius: 0 12px 12px 0;" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-600 text-secondary small mb-1">Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                        <i class="bi bi-lock text-muted"></i>
                    </span>
                    <input name="password" type="password" class="form-control border-start-0 py-2" placeholder="••••••••" style="border-radius: 0 12px 12px 0;" required />
                </div>
            </div>

            <button type="submit" class="btn w-100 py-3 fw-bold text-white shadow-sm mb-3"
                    style="background-color: var(--portal-emerald); border-radius: 12px; font-size: 1rem;">
                Sign In <i class="bi bi-box-arrow-in-right ms-1"></i>
            </button>
        </form>

        <div class="text-center">
            <p class="small text-muted mb-0">
                Don't have an account?
                <a asp-action="Register" class="fw-bold text-decoration-none" style="color: var(--portal-emerald);">Register here</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

