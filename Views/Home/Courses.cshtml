@model IEnumerable<UniversityAcademicManagementSystem.Models.Course>

@{
    ViewData["Title"] = "Course Catalog - ABC University";
}

<div class="container mt-5 pb-5">
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-light shadow-sm px-4 fw-bold text-secondary"
               style="border-radius: 12px; border: 1px solid #e2e8f0; font-size: 0.9rem;">
            <i class="bi bi-arrow-left me-2"></i>Back to Home
        </a>
    </div>

    <div class="text-center mb-5">
        <h1 class="fw-bold" style="color: var(--portal-navy); letter-spacing: -1.5px;">Academic Courses</h1>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Explore our wide range of academic programs and courses designed to shape your future.
        </p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm p-4 card-hover" style="border-radius: 20px; transition: transform 0.2s;">
                        <div class="d-flex align-items-start justify-content-between mb-3">
                            <div class="p-3 rounded-3" style="background: rgba(16, 185, 129, 0.1); color: var(--portal-emerald);">
                                <i class="bi bi-journal-text fs-3"></i>
                            </div>
                            <span class="badge rounded-pill px-3 py-2 fw-semibold"
                                  style="background-color: #f0fdf4; color: #166534; font-size: 0.7rem; border: 1px solid #dcfce7;">
                                @course.Department
                            </span>
                        </div>

                        <h5 class="fw-bold mb-2" style="color: var(--portal-navy);">@course.CourseName</h5>
                        
                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <div class="small text-muted">
                                <i class="bi bi-mortarboard me-1"></i> Sem @course.SemesterOffered
                            </div>
                            <div class="fw-bold" style="color: var(--portal-emerald);">
                                @course.Credits Credits
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search fs-1 text-muted"></i>
                <h4 class="mt-3 text-muted">No courses found in the catalog.</h4>
            </div>
        }
    </div>
</div>