@{
    ViewData["Title"] = "Change Password - ABC University";
}

<div class="container-fluid d-flex align-items-center justify-content-center min-vh-100" style="background-color: var(--portal-slate);">
    <div class="card shadow-sm border-0 p-4 p-md-5" style="max-width: 450px; width: 100%; border-radius: 24px; background: #fff;">
        
        <div class="text-center mb-4">
            <div class="d-inline-block p-3 rounded-circle mb-3" style="background: rgba(16, 185, 129, 0.1);">
                <i class="bi bi-shield-lock" style="font-size: 2.2rem; color: var(--portal-emerald);"></i>
            </div>
            <h2 class="fw-bold" style="color: var(--portal-navy); letter-spacing: -1px;">Update Password</h2>
            <p class="text-muted small">Ensure your account stays secure.</p>
        </div>

        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary small mb-1">Current Password</label>
                <input name="currentPassword" type="password" class="form-control py-2 bg-light border-0 shadow-none" style="border-radius: 12px;" required />
            </div>

            <hr class="my-4 opacity-25">

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary small mb-1">New Password</label>
                <input name="newPassword" type="password" class="form-control py-2 bg-light border-0 shadow-none" style="border-radius: 12px;" required />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary small mb-1">Confirm New Password</label>
                <input name="confirmPassword" type="password" class="form-control py-2 bg-light border-0 shadow-none" style="border-radius: 12px;" required />
            </div>

            <button type="submit" class="btn w-100 py-2 fw-bold text-white shadow-sm mb-3"
                    style="background-color: var(--portal-emerald); border-radius: 12px;">
                Update Password <i class="bi bi-check2-circle ms-1"></i>
            </button>

            <button type="button" onclick="window.history.back()" class="btn btn-light w-100 py-2 fw-bold border" style="border-radius: 12px; color: #64748b;">
                Cancel
            </button>
        </form>
    </div>
</div>