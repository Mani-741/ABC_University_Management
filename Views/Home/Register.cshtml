@model User

@{
    ViewData["Title"] = "Register - ABC University";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid d-flex align-items-center justify-content-center min-vh-100" style="background-color: var(--portal-slate);">
    
    <div class="card shadow-sm border-0 p-4 p-md-5" style="max-width: 450px; width: 100%; border-radius: 24px; background: #fff;">
        
        <div class="text-center mb-4">
            <div class="d-inline-block p-3 rounded-circle mb-3" style="background: rgba(16, 185, 129, 0.1);">
                <i class="bi bi-shield-lock-fill" style="font-size: 2.2rem; color: var(--portal-emerald);"></i>
            </div>
            <h2 class="fw-bold" style="color: var(--portal-navy); letter-spacing: -1px;">Student Register</h2>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-600 text-secondary small mb-1" asp-for="Email">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                        <i class="bi bi-envelope text-muted"></i>
                    </span>
                    <input asp-for="Email" class="form-control border-start-0 py-2" placeholder="name@university.edu" style="border-radius: 0 12px 12px 0;" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-600 text-secondary small mb-1" asp-for="Password">Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                        <i class="bi bi-lock text-muted"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 py-2" placeholder="••••••••" style="border-radius: 0 12px 12px 0;" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-600 text-secondary small mb-1" asp-for="ConfirmPassword">Confirm Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px;">
                        <i class="bi bi-shield-check text-muted"></i>
                    </span>
                    <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0 py-2" placeholder="Re-type password" style="border-radius: 0 12px 12px 0;" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn w-100 py-2 fw-bold text-white shadow-sm"
                    style="background-color: var(--portal-emerald); border-radius: 12px;">
                Register Now <i class="bi bi-arrow-right-short ms-1"></i>
            </button>
        </form>

        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-3 d-flex align-items-center"
                 style="border-radius: 12px; background-color: #ecfdf5; color: #065f46; font-size: 0.85rem;">
                <i class="bi bi-check-circle-fill me-2"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        <div class="text-center mt-4">
            <p class="small text-muted mb-0">
                Already have an account? <a asp-action="Login" class="fw-bold text-decoration-none" style="color: var(--portal-emerald);">Sign In</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}