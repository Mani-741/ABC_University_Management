@model UniversityAcademicManagementSystem.Models.Student

@{
    ViewData["Title"] = "My Profile - ABC University";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-10">
            <div class="card shadow-sm border-0 overflow-hidden" style="border-radius: 16px;">
                <div class="px-4 py-3 text-white d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, var(--portal-emerald));">
                    <div>
                        <h5 class="fw-bold mb-0">My Profile</h5>
                    </div>
                    <a asp-action="EditProfile" class="btn btn-sm btn-light fw-bold px-3 shadow-sm" style="border-radius: 8px; color: var(--portal-navy);">
                        <i class="bi bi-pencil-square me-1"></i>Edit
                    </a>
                </div>

                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle d-flex align-items-center justify-content-center bg-light"
                             style="width: 70px; height: 70px; color: var(--portal-emerald); border: 2px solid rgba(16, 185, 129, 0.2);">
                            <i class="bi bi-person-fill" style="font-size: 2.5rem;"></i>
                        </div>
                        <div class="ms-3">
                            <h4 class="fw-bold mb-0" style="color: var(--portal-navy);">@Model.Name</h4>
                            <div class="d-flex align-items-center gap-2 mt-1">
                                <small class="text-muted fw-bold">ID: #@Model.StudentId</small>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2" style="font-size: 0.7rem;">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Active
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="p-2 px-3 border rounded-3 bg-light bg-opacity-50">
                                <label class="text-muted fw-bold mb-0" style="font-size: 0.75rem;">Department</label>
                                <p class="mb-0 fw-semibold text-dark">@Model.Department</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 px-3 border rounded-3 bg-light bg-opacity-50">
                                <label class="text-muted fw-bold mb-0" style="font-size: 0.75rem;">Email Address</label>
                                <p class="mb-0 fw-semibold text-dark" style="font-size: 0.9rem;">@Model.Email</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 px-3 border rounded-3 bg-light bg-opacity-50">
                                <label class="text-muted fw-bold mb-0" style="font-size: 0.75rem;">Contact Number</label>
                                <p class="mb-0 fw-semibold text-dark">@(string.IsNullOrEmpty(Model.ContactNumber) ? "N/A" : Model.ContactNumber)</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 px-3 border rounded-3 bg-light bg-opacity-50">
                                <label class="text-muted fw-bold mb-0" style="font-size: 0.75rem;">Enrollment Year</label>
                                <p class="mb-0 fw-semibold text-dark">@Model.EnrollmentYear</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-center">
                        <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>