@model IEnumerable<UniversityAcademicManagementSystem.Models.Course>

@{
    ViewData["Title"] = "Available Courses - ABC University";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0" style="color: var(--portal-navy);">Available Courses</h4>
            <p class="text-muted small mb-0">Courses offered in your department</p>
        </div>
        <a asp-action="EnrolledCourses" class="btn btn-sm btn-outline-secondary fw-bold px-3" style="border-radius: 8px;">
            <i class="bi bi-journal-check me-1"></i> My Enrollments
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
            <i class="bi bi-book text-muted display-4"></i>
            <p class="mt-3 text-muted">No new courses available for enrollment at the moment.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var course in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm card-hover" style="border-radius: 16px; transition: transform 0.2s;">
                        <div class="card-body p-4 d-flex flex-column">

                            <h5 class="fw-bold mb-2" style="color: var(--portal-navy); min-height: 48px;">@course.CourseName</h5>
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between text-muted mb-3 small border-top pt-2">
                                    <span><i class="bi bi-star me-1"></i>Credits: @course.Credits</span>
                                    <span><i class="bi bi-calendar3 me-1"></i>Sem: @course.SemesterOffered</span>
                                </div>

                                <form asp-action="Enroll" method="post">
                                    <input type="hidden" name="courseId" value="@course.CourseId" />
                                    <button type="submit" class="btn btn-emerald text-white fw-bold w-100 py-2 shadow-sm"
                                            style="background-color: var(--portal-emerald); border-radius: 10px;">
                                        Enroll Now
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4 text-center">
        <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>
</div>