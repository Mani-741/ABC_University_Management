@model IEnumerable<UniversityAcademicManagementSystem.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrolled Courses - ABC University";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0" style="color: var(--portal-navy);">My Enrolled Courses</h4>
            <p class="text-muted small mb-0">List of your currently active subjects</p>
        </div>
        <a asp-action="AvailableCourses" class="btn btn-sm btn-emerald text-white fw-bold px-3 shadow-sm"
               style="background-color: var(--portal-emerald); border-radius: 8px;">
            <i class="bi bi-plus-lg me-1"></i> Enroll New
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 16px;">
            <div class="mb-3">
                <i class="bi bi-journal-x text-muted" style="font-size: 3rem;"></i>
            </div>
            <h5 class="fw-bold">No active enrollments found</h5>
            <p class="text-muted small">You haven't enrolled in any courses yet.</p>
            <a asp-action="AvailableCourses" class="btn btn-outline-emerald btn-sm fw-bold mt-2" style="border-radius: 8px;">
                Browse Catalog
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm" style="border-radius: 12px; border-left: 5px solid var(--portal-emerald) !important;">
                        <div class="card-body p-3 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded p-2 text-center me-3" style="width: 50px;">
                                    <i class="bi bi-journal-text text-emerald fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0" style="color: var(--portal-navy);">@item.Course.CourseName</h6>
                                    <small class="text-muted">
                                        Credits: @item.Course.Credits
                                    </small>
                                </div>
                            </div>

                            <form asp-action="DropCourse" method="post" onsubmit="return confirm('Are you sure you want to drop from this course?');">
                                <input type="hidden" name="enrollmentId" value="@item.EnrollmentId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3 fw-bold" style="border-radius: 8px;">
                                    <i class="bi bi-trash3 me-1"></i> Drop
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4 text-center">
        <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>
</div>