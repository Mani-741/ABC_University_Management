@model UniversityAcademicManagementSystem.Models.Student

@{
    ViewData["Title"] = "Edit Profile - ABC University";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-9">
            <div class="card shadow-sm border-0" style="border-radius: 16px;">
                <div class="px-4 py-3 text-white" style="background: var(--portal-emerald); border-radius: 16px 16px 0 0;">
                    <h5 class="fw-bold mb-0">Update Information</h5>
                    <small class="opacity-75">Edit your personal details below</small>
                </div>

                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post">
                        <input type="hidden" asp-for="StudentId" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-bold small text-muted mb-1">Full Name</label>
                                <input asp-for="Name" class="form-control border-0 bg-light shadow-none"
                                       style="border-radius: 8px; padding: 10px;" placeholder="Enter name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-7">
                                <label asp-for="ContactNumber" class="form-label fw-bold small text-muted mb-1">Contact No.</label>
                                <input asp-for="ContactNumber" class="form-control border-0 bg-light shadow-none"
                                       style="border-radius: 8px; padding: 10px;" placeholder="Phone number" />
                                <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-5">
                                <label asp-for="EnrollmentYear" class="form-label fw-bold small text-muted mb-1">Year</label>
                                <input asp-for="EnrollmentYear" class="form-control border-0 bg-light shadow-none"
                                       style="border-radius: 8px; padding: 10px;" readonly />
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Department" class="form-label fw-bold small text-muted mb-1">Department</label>
                                <input asp-for="Department" class="form-control border-0 bg-light shadow-none"
                                       style="border-radius: 8px; padding: 10px;" readonly />
                            </div>
                        </div>

                        <div class="mt-4 pt-2 d-flex gap-2">
                            <button type="submit" class="btn btn-emerald text-white fw-bold w-100 py-2"
                                    style="background-color: var(--portal-emerald); border-radius: 8px;">
                                Save Changes
                            </button>
                            <a asp-action="Profile" class="btn btn-light fw-bold w-100 py-2"
                                   style="border-radius: 8px; border: 1px solid #dee2e6;">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}