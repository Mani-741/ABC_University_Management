<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Portal</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark sticky-top mb-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center"
                       asp-controller="@(User.Identity.IsAuthenticated && User.IsInRole("Admin") ? "Admin" : "Home")"
                       asp-action="Index">
    
                    <div class="p-1 rounded me-2 logo-box">
                        <i class="bi bi-mortarboard-fill text-white fs-5"></i>
                    </div>
                    ABC UNIVERSITY
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">
                    <ul class="navbar-nav ms-lg-4">
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i> Admin Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Home" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2 text-warning"></i> Change Password
                                </a>
                            </li>
                        }
                        else if (User.Identity.IsAuthenticated && User.IsInRole("Registrar"))
                        {
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Registrar" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Registrar Dashboard
                            </a>
                        </li>

                            <li>
                                <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Home" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2 text-warning"></i> Change Password
                                </a>
                            </li>

                        }
                        else if (User.Identity.IsAuthenticated && User.IsInRole("Faculty"))
                        {
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Faculty" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Faculty Dashboard
                            </a>
                        </li>

                            <li>
                                <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Home" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2 text-warning"></i> Change Password
                                </a>
                            </li>
                        }
                        else if (User.Identity.IsAuthenticated && User.IsInRole("Student"))
                        {
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Student Dashboard
                            </a>
                        </li>

                            <li>
                                <a class="nav-link fw-bold text-white shadow-sm rounded-pill px-3 bg-opacity-10 bg-white" asp-controller="Home" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2 text-warning"></i> Change Password
                                </a>
                            </li>
                        }
                        else
                        {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Courses">Courses</a>
                        </li>
                        }
                    </ul>
                    
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center bg-dark rounded-pill px-3 py-1 border border-secondary shadow-sm"
                                       href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                                       style="transition: all 0.3s ease;">
                                    
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-2"
                                         style="width: 28px; height: 28px; background-color: var(--portal-emerald);">
                                        <i class="bi bi-person-fill text-white" style="font-size: 0.85rem;"></i>
                                    </div>
                                    <span class="text-white small fw-bold">@User.Identity.Name</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 p-2"
                                    aria-labelledby="userDropdown" style="border-radius: 12px; min-width: 200px;">
                                    
                                    <li class="px-3 py-2 border-bottom mb-1">
                                        <p class="text-muted mb-0" style="font-size: 0.7rem; font-weight: 700;">
                                            @(User.IsInRole(Role.Admin.ToString()) ? "Administrator" : "User Account")
                                        </p>
                                        <p class="text-dark fw-bold mb-0 small text-truncate">@User.Identity.Name</p>
                                    </li>
                                        @if (User.IsInRole("Student"))
                                        {
                                            <li>
                                                <a class="dropdown-item py-2 d-flex align-items-center rounded-3" asp-controller="Student" asp-action="Profile">
                                                    <i class="bi bi-person-circle me-2 text-primary"></i> My Profile
                                                </a>
                                            </li>
                                        }

                                    <li><hr class="dropdown-divider opacity-50"></li>

                                    <li>
                                        <form asp-controller="Home" asp-action="Logout" method="post" class="d-grid px-2">
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0 d-flex align-items-center py-2">
                                                <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn-login px-4" asp-controller="Home" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 small py-2 mb-3" role="alert" style="border-radius: 12px;">
                    <i class="bi bi-check-circle me-1"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close small" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.8rem 1rem; font-size: 0.6rem;"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="text-muted border-top bg-white mt-auto py-4">
        <div class="container text-center">
            <p class="mb-1">&copy; @DateTime.Now.Year - <span class="fw-bold text-dark">ABC University</span></p>
            <div class="small">
                <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted mx-2">Privacy Policy</a> &bull;
                <a href="#" class="text-decoration-none text-muted mx-2">Support Center</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>