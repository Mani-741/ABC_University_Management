@{
    Layout = "_Layout";
    ViewData["Title"] = "Error - ABC University";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center shadow-sm p-5 bg-white rounded-4 border">
            
            <div class="mb-4">
                <i class="bi bi-exclamation-octagon-fill" style="font-size: 4rem; color: #ef4444;"></i>
            </div>

            <h2 class="fw-bold mb-3" style="color: var(--portal-navy);">Unexpected Error Occured!</h2>
            
            <p class="text-muted mb-4">
                An unexpected server error has occurred. We will try to fix it soon.
                In the meantime, you can return to the dashboard or home page.
            </p>

            <div class="d-flex gap-2 justify-content-center">
                <button onclick="window.history.back()" class="btn btn-outline-secondary px-4 fw-bold" style="border-radius: 10px;">
                    <i class="bi bi-arrow-left me-1"></i> Go Back
                </button>

                <a asp-controller="Home" asp-action="Index" class="btn text-white px-4 fw-bold"
                       style="background-color: var(--portal-emerald); border-radius: 10px;">
                    <i class="bi bi-house-door me-1"></i> Home
                </a>
            </div>

        </div>
    </div>
</div>