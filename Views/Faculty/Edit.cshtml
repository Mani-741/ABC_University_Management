@model UniversityAcademicManagementSystem.Models.Grade

@{
    ViewData["Title"] = "Edit Grade - ABC University";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 rounded-3 overflow-hidden">
                
                <div class="card-header text-white p-3 text-center border-0" style="background-color: #10b981">
                    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Student Grade</h5>
                </div>

                <div class="card-body p-3 bg-white">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="GradeId" />
                        <input type="hidden" asp-for="StudentId" />
                        <input type="hidden" asp-for="CourseId" />

                        <div class="mb-3 bg-light p-2 rounded-3 border-start border-4 border-success">
                            <label class="text-muted small fw-bold text-uppercase d-block">Student</label>
                            <span class="fw-bold text-dark">@Model.Student?.Name</span>
                            <span class="text-muted small">(ID: @Model.StudentId)</span>
                        </div>

                        <div class="mb-4 bg-light p-2 rounded-3 border-start border-4 border-info">
                            <label class="text-muted small fw-bold text-uppercase d-block">Course</label>
                            <span class="fw-bold text-dark">@Model.Course?.CourseName</span>
                        </div>

                        <hr class="my-3 opacity-25">

                        <div class="row g-2">
                            <div class="col-sm-4">
                                <label asp-for="GradeValue" class="form-label fw-bold text-secondary small text-uppercase">Grade</label>
                                <select asp-for="GradeValue" class="form-select border-2 shadow-none rounded-3">
                                    <option value="A">A</option>
                                    <option value="B">B</option>
                                    <option value="C">C</option>
                                    <option value="D">D</option>
                                    <option value="E">E</option>
                                    <option value="F">F</option>
                                </select>
                            </div>
                            <div class="col-sm-8">
                                <label asp-for="Remarks" class="form-label fw-bold text-secondary small text-uppercase">Remarks</label>
                                <input asp-for="Remarks" class="form-control border-2 shadow-none rounded-3" placeholder="Optional" />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success fw-bold shadow-sm w-100 rounded-3 py-2 border-0" style="background-color: #198754;">
                                <i class="bi bi-save me-2"></i>Update Grade
                            </button>
                            <div class="text-center">
                                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted mt-2 btn-sm">Cancel and Return</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}