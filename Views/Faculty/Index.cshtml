@model IEnumerable<UniversityAcademicManagementSystem.Models.Grade>

@{
    ViewData["Title"] = "Grading Portal - ABC University";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container mt-5 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="fw-bold" style="color: var(--portal-navy); letter-spacing: -1px;">Grading Portal</h2>
            <p class="text-muted mb-0">Manage student academic performances</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="AddGrade" class="btn text-white px-4 py-2 fw-bold shadow-sm card-hover"
                   style="background-color: var(--portal-emerald); border-radius: 12px;">
                <i class="bi bi-plus-circle-fill me-2"></i>Assign New Grade
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small fw-bold text-uppercase">Student</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Course</th>
                        <th class="py-3 text-center text-secondary small fw-bold text-uppercase">Grade</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Remarks</th>
                        <th class="pe-4 py-3 text-center text-secondary small fw-bold text-uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold mb-0" style="color: var(--portal-navy);">@item.Student?.Name</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">ID: #@item.StudentId</div>
                                </td>

                                <td class="py-3">@item.Course?.CourseName</td>

                                <td class="py-3 text-center">
                                    <span class="badge rounded-pill px-3 py-2 fw-semibold @(item.GradeValue == "F" ? "bg-danger text-white" : "bg-success text-white")">
                                        @item.GradeValue
                                    </span>
                                </td>

                                <td class="py-3">@item.Remarks</td>

                                <td class="pe-4 py-3">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.GradeId" class="btn btn-sm btn-light border shadow-sm" style="border-radius: 8px;" title="Edit">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.GradeId" method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this grade record?');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-light border shadow-sm" style="border-radius: 8px;" title="Delete">
                                                <i class="bi bi-trash3-fill text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No grades assigned yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>