@model UniversityAcademicManagementSystem.Models.Grade
@using UniversityAcademicManagementSystem.Models

@{
    ViewData["Title"] = "Assign Grade - ABC University";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 rounded-3 overflow-hidden">
                
                <div class="card-header text-white p-3 text-center border-0" style="background-color: #10b981">
                    <h5 class="fw-bold mb-0"><i class="bi bi-mortarboard-fill me-2"></i>Grading Portal</h5>
                </div>

                <div class="card-body p-3 bg-white">
                    
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small mb-3 rounded-3 shadow-sm py-2"></div>

                    <form asp-action="AddGrade" method="post">
                        <input type="hidden" name="actionType" id="actionType" value="Save" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small text-uppercase" style="letter-spacing: 0.5px;">1. Department</label>
                            <select name="dept" class="form-select border-2 shadow-none bg-light rounded-3"
                                    onchange="document.getElementById('actionType').value='Refresh'; this.form.submit();"
                                    style="cursor: pointer;">
                                <option value="">-- Choose Dept --</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var d in (List<string>)ViewBag.Departments)
                                    {
                                        <!option value="@d" @(ViewBag.SelectedDept == d ? "selected" : "")>@d</!option>
                                    }
                                }
                            </select>
                        </div>

                        @if (ViewBag.Courses != null)
                        {
                            <div class="mb-3">
                                <label asp-for="CourseId" class="form-label fw-bold text-secondary small text-uppercase" style="letter-spacing: 0.5px;">2. Course</label>
                                <select asp-for="CourseId" class="form-select border-2 shadow-none bg-light rounded-3"
                                        onchange="document.getElementById('actionType').value='Refresh'; this.form.submit();"
                                        style="cursor: pointer;">
                                    <option value="">-- Choose Course --</option>
                                    @foreach (var c in (IEnumerable<Course>)ViewBag.Courses)
                                    {
                                        <!option value="@c.CourseId" @(ViewBag.SelectedCourse == c.CourseId ? "selected" : "")>
                                            @c.CourseName
                                        </!option>
                                    }
                                </select>
                            </div>
                        }

                        @if (ViewBag.Students != null)
                        {
                            <div class="mb-3">
                                <label asp-for="StudentId" class="form-label fw-bold text-secondary small text-uppercase" style="letter-spacing: 0.5px;">3. Student</label>
                                <select asp-for="StudentId" class="form-select border-2 shadow-none bg-light rounded-3" required>
                                    <option value="">-- Choose Student --</option>
                                    @foreach (var s in (IEnumerable<dynamic>)ViewBag.Students)
                                    {
                                        <option value="@s.StudentId">@s.Name (ID: @s.StudentId)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentId" class="text-danger small"></span>
                            </div>

                            <div class="row g-2">
                                <div class="col-sm-4">
                                    <label asp-for="GradeValue" class="form-label fw-bold text-secondary small text-uppercase">Grade</label>
                                    <select asp-for="GradeValue" class="form-select border-2 shadow-none rounded-3">
                                        <option value="A">A</option>
                                        <option value="B">B</option>
                                        <option value="C">C</option>
                                        <option value="D">D</option>
                                        <option value="E">E</option>
                                        <option value="F">F</option>
                                    </select>
                                </div>
                                <div class="col-sm-8">
                                    <label asp-for="Remarks" class="form-label fw-bold text-secondary small text-uppercase">Remarks</label>
                                    <input asp-for="Remarks" class="form-control border-2 shadow-none rounded-3" placeholder="Optional" />
                                </div>
                            </div>

                            <div class="mt-4">
                                <button type="submit" class="btn btn-success fw-bold shadow-sm w-100 rounded-3 py-2 border-0" style="background-color: #198754;">
                                    <i class="bi bi-check2-circle me-2"></i>Save Grade
                                </button>
                                <div class="text-center">
                                    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted mt-2 btn-sm">Cancel and Return</a>
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
